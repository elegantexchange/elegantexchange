# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=elegantexchange

# Auth
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=shop@elegantexchange.co
ADMIN_PASSWORD=change-me
ADMIN_NAME=Owner
CORS_ORIGINS=http://localhost:3000

# Frontend URL (OAuth redirect after Square connects)
FRONTEND_URL=http://localhost:3000

# Square — https://developer.squareup.com/apps
# Sandbox: use Sandbox Application ID/Secret, SQUARE_ENVIRONMENT=sandbox
# Production (go-live): switch app to Production in Square dashboard
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_REDIRECT_URI=http://localhost:8000/api/square/callback
SQUARE_ENVIRONMENT=sandbox

# Optional: reload demo data on empty DB (leave unset for production)
# SEED_DEMO=true
